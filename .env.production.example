# Production environment template for the 96well application.
# This file contains placeholders only. Do not put real credentials or real
# production URLs in this repository.
#
# Production runtime must use POSTGRES_APP_DATABASE_URL.
# POSTGRES_PRISMA_DATABASE_URL is for migration execution only.
# Never use the migration database user for application runtime.
# Never use SQLite in production.

NODE_ENV=production

# Migration-only PostgreSQL connection.
# Use only for approved Prisma/PostgreSQL migration operations.
POSTGRES_PRISMA_DATABASE_URL=postgresql://MIGRATION_USER:PASSWORD@HOST:5432/DB_NAME

# Application runtime PostgreSQL connection.
# The deployed application must use this app-user connection at runtime.
POSTGRES_APP_DATABASE_URL=postgresql://APP_USER:PASSWORD@HOST:5432/DB_NAME

# Production OIDC resource-server validation.
# Use production-approved issuer, audience, and JWKS metadata from the
# deployment platform secret manager.
OIDC_ISSUER=https://OIDC_ISSUER_PLACEHOLDER/
OIDC_AUDIENCE=OIDC_AUDIENCE_PLACEHOLDER
OIDC_JWKS_URL=https://OIDC_JWKS_URL_PLACEHOLDER/.well-known/jwks.json
