# 96well research limited external preview template.
# Placeholder values only. Never commit real credentials, real URLs, tokens, patient data, or clinical data.

NODE_ENV=production

# Enables research-public fail-closed behavior.
RESEARCH_PUBLIC_MODE=true

# Application runtime database. Store the real value in the deployment secret manager.
# Must be an app-user PostgreSQL connection. Do not use migration credentials here.
POSTGRES_APP_DATABASE_URL=

# Existing application authentication remains required after Cloudflare Access.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# Cloudflare Access application-side verification.
# Use the Cloudflare Access team domain, application audience, and canonical application hostnames.
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_JWKS_URL=
RESEARCH_PUBLIC_ALLOWED_HOSTS=

# Temporary staging-only diagnostics for failed API responses.
# Keep unset or false by default. Enable briefly only while investigating staging errors,
# then remove it again. Debug output is secret-redacted and limited to research-public production mode.
RESEARCH_PUBLIC_DEBUG_ERRORS=false

# Phase 1 disables image upload/analysis by default.
NEXT_PUBLIC_IMAGE_REVIEW_ENABLED=false
RESEARCH_PUBLIC_IMAGE_REVIEW_ENABLED=false
RESEARCH_PUBLIC_IMAGE_UPLOAD_ENABLED=false

# Migration-only values must not be configured in Netlify runtime.
# POSTGRES_PRISMA_DATABASE_URL is intentionally omitted here.
