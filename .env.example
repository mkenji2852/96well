DATABASE_URL="file:./dev.db"

# PostgreSQL production / CI. Use different credentials for migration and runtime.
# Never commit real passwords. Production must use PostgreSQL; SQLite is refused in production.
POSTGRES_PRISMA_DATABASE_URL="postgresql://ast_migration:dummy_password@localhost:5432/ast?schema=public"
POSTGRES_APP_DATABASE_URL="postgresql://ast_app:dummy_password@localhost:5432/ast?schema=public"
POSTGRES_TEST_DATABASE_URL="postgresql://ast_migration:dummy_password@localhost:5432/ast_test?schema=public"
POSTGRES_APP_TEST_DATABASE_URL="postgresql://ast_app:dummy_password@localhost:5432/ast_test?schema=public"
POSTGRES_RESTORE_TEST_DATABASE_URL="postgresql://ast_migration:dummy_password@localhost:5432/ast_restore?schema=public"

# Production OIDC resource-server validation. Do not commit client secrets.
OIDC_ISSUER=""
OIDC_AUDIENCE=""
OIDC_JWKS_URL=""

# Development only. Requires NODE_ENV=development and an existing DB user.
DEV_AUTH_ENABLED="false"
DEV_AUTH_USER_ID=""

# Research limited external preview. Do not use for clinical/diagnostic/regulated use.
# In production with RESEARCH_PUBLIC_MODE=true, Cloudflare Access JWT and allowed host config are required.
RESEARCH_PUBLIC_MODE="false"
CLOUDFLARE_ACCESS_TEAM_DOMAIN=""
CLOUDFLARE_ACCESS_AUD=""
CLOUDFLARE_ACCESS_JWKS_URL=""
RESEARCH_PUBLIC_ALLOWED_HOSTS=""
RESEARCH_PUBLIC_IMAGE_REVIEW_ENABLED="false"
RESEARCH_PUBLIC_IMAGE_UPLOAD_ENABLED="false"

# Disable the reviewer/admin image review UI and its client-side API calls when false.
NEXT_PUBLIC_IMAGE_REVIEW_ENABLED="true"
